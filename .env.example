# Copy this file to `.env` and fill in your TradeLocker credentials.
# `.env` is gitignored — never commit real credentials.

# TradeLocker login (the same username/password/server you use in the web app).
TRADELOCKER_USERNAME=you@example.com
TRADELOCKER_PASSWORD=your-password
TRADELOCKER_SERVER=YOUR-SERVER-NAME

# Default to the LIVE environment? Leave unset/0 for DEMO.
# CLI flags (--demo / --live / --paper) always override this.
PROPSHIELD_LIVE=0
